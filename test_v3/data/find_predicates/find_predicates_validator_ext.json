{
  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["plain", "enc", "nested", "tags", "items"],
      "properties": {
        "plain": { "bsonType": "string" },

        "enc": { "bsonType": "string", "encryption": "AES256_CTR" },

        "nested": {
          "bsonType": "object",
          "required": ["enc2", "plain2"],
          "properties": {
            "enc2": { "bsonType": "string", "encryption": "AES256_CTR" },
            "plain2": { "bsonType": "string" }
          }
        },

        "tags": {
          "bsonType": "array",
          "items": { "bsonType": "string", "encryption": "AES256_CTR" }
        },

        "items": {
          "bsonType": "array",
          "items": {
            "bsonType": "object",
            "required": ["sku", "secretNote"],
            "properties": {
              "sku": { "bsonType": "string" },
              "secretNote": { "bsonType": "string", "encryption": "AES256_CTR" }
            }
          }
        }
      }
    }
  }
}